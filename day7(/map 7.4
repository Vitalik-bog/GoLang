package main

import (
	"fmt"
	"strings" 
)

func main() {
    text := "apple banana apple orange banana banana"
    words := strings.Fields(text)  
    count := make(map[string]int)

    for _, word := range words {
        count[word]++
    }
    for word, cnt := range count {
        fmt.Printf("%s -> %d\n", word, cnt)
    }
}
