package main

import "fmt"

type Rectangle struct {
	Width  float64
	Height float64
}

func (r Rectangle) Area() float64 {
	return r.Height * r.Width
}
func (r Rectangle) Perimeter() float64 {
	return (r.Height * r.Width) * 2
}
func main() {
	rect := Rectangle{
		Width:  10,
		Height: 5,
	}
  fmt.Printf("Площадь :%f\n",rect.Area())
  fmt.Printf("Периметр:%f\n",rect.Perimeter())
}
